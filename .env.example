# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── Alpaca (paper) ──────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# ── Live trading double-lock (leave UNSET for paper) ────────
# Live requires BOTH config.yaml `mode: live` AND this exact string:
LIVE_TRADING_CONFIRM=            # must equal: I_UNDERSTAND_LIVE_TRADING

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./trading_assistant.db

# ── Telegram (optional, Phase 4) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App ─────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
