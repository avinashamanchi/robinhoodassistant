# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.

# ── LLM providers (pick with llm.provider in config.yaml) ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
GEMINI_API_KEY=            # Google AI Studio key (provider: gemini)
GROQ_API_KEY=             # Groq key (provider/fallback: groq)

# ── Market data ─────────────────────────────────────────────
MARKETSTACK_API_KEY=      # equities EOD/historical/splits/dividends (CoinGecko needs no key)

# ── Alpaca (paper) ──────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# ── Live trading double-lock (leave UNSET for paper) ────────
# Live requires BOTH config.yaml `mode: live` AND this exact string:
LIVE_TRADING_CONFIRM=            # must equal: I_UNDERSTAND_LIVE_TRADING

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./trading_assistant.db

# ── Telegram (optional, Phase 4) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Robinhood (READ-ONLY external source; never places orders) ──
RH_USERNAME=
RH_PASSWORD=
RH_TOTP_SECRET=            # the 2FA setup key from Robinhood's authenticator setup
RH_TOKEN_PATH=./.rh_token.pickle

# ── App ─────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
